# ── Variables de entorno para la integración WhatsApp ──────────────────────
# Copia este archivo a .env.whatsapp y rellena los valores reales.
# NUNCA subas .env.whatsapp a git.

# Clave de la API de Groq (modelo LLaMA 3.3 70B)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Clave para proteger la API de open-wa (pon cualquier string secreto)
OPENWA_API_KEY=mi_clave_secreta_openwa
